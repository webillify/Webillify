generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  INVITED
  ACTIVE
  LOCKED
  DISABLED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum OrganizationStatus {
  TRIALING
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum AiCreditEntryType {
  GRANT
  CONSUME
  REFUND
  EXPIRE
  PURCHASE
}

enum ProductType {
  GOODS
  SERVICE
}

enum PriceTaxMode {
  EXCLUSIVE
  INCLUSIVE
}

enum StockMovementType {
  OPENING_STOCK
  PURCHASE_RECEIPT
  PURCHASE_RETURN
  SALE_ISSUE
  SALES_RETURN
  TRANSFER_DISPATCH
  TRANSFER_RECEIPT
  TRANSFER_DIFFERENCE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  DAMAGE
  EXPIRY
  SCRAP
  REVERSAL
}

enum PurchaseBillStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum SupplierPaymentStatus {
  POSTED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK
  UPI
  CARD
  OTHER
}

model User {
  id                     String                   @id @default(uuid()) @db.Uuid
  email                  String                   @unique @db.VarChar(320)
  normalizedEmail        String                   @unique @map("normalized_email") @db.VarChar(320)
  displayName            String                   @map("display_name") @db.VarChar(160)
  passwordHash           String?                  @map("password_hash") @db.VarChar(255)
  status                 UserStatus               @default(INVITED)
  emailVerifiedAt        DateTime?                @map("email_verified_at") @db.Timestamptz(3)
  lastLoginAt            DateTime?                @map("last_login_at") @db.Timestamptz(3)
  createdAt              DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  memberships            OrganizationMembership[]
  sessions               LoginSession[]
  stockMovements         StockMovement[]          @relation("StockMovementActor")
  postedPurchaseBills    PurchaseBill[]           @relation("PurchaseBillPostedBy")
  cancelledPurchaseBills PurchaseBill[]           @relation("PurchaseBillCancelledBy")
  postedPurchaseReturns  PurchaseReturn[]         @relation("PurchaseReturnPostedBy")
  supplierPayments       SupplierPayment[]        @relation("SupplierPaymentActor")

  @@map("users")
}

model Organization {
  id               String                   @id @default(uuid()) @db.Uuid
  name             String                   @db.VarChar(180)
  slug             String                   @unique @db.VarChar(100)
  status           OrganizationStatus       @default(TRIALING)
  locale           String                   @default("en-IN") @db.VarChar(16)
  timezone         String                   @default("Asia/Kolkata") @db.VarChar(64)
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  memberships      OrganizationMembership[]
  companies        Company[]
  branches         Branch[]
  roles            Role[]
  coreSubscription Subscription?
  aiSubscription   AiSubscription?
  aiCreditEntries  AiCreditLedger[]
  auditLogs        AuditLog[]
  categories       Category[]
  units            Unit[]
  taxRates         TaxRate[]
  products         Product[]
  productVariants  ProductVariant[]
  productBarcodes  ProductBarcode[]
  warehouses       Warehouse[]
  stockMovements   StockMovement[]
  stockBalances    StockBalance[]
  suppliers        Supplier[]
  purchaseBills    PurchaseBill[]
  purchaseReturns  PurchaseReturn[]
  supplierPayments SupplierPayment[]

  @@map("organizations")
}

model OrganizationMembership {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  userId         String             @map("user_id") @db.Uuid
  status         MembershipStatus   @default(INVITED)
  joinedAt       DateTime?          @map("joined_at") @db.Timestamptz(3)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user           User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  roles          MembershipRole[]
  branchAccess   UserBranchAccess[]

  @@unique([organizationId, userId])
  @@unique([id, organizationId])
  @@index([userId, status])
  @@map("organization_memberships")
}

model Company {
  id                String            @id @default(uuid()) @db.Uuid
  organizationId    String            @map("organization_id") @db.Uuid
  legalName         String            @map("legal_name") @db.VarChar(200)
  tradeName         String?           @map("trade_name") @db.VarChar(200)
  normalizedCode    String            @map("normalized_code") @db.VarChar(40)
  gstin             String?           @db.VarChar(15)
  financialYearFrom Int               @default(4) @map("financial_year_from") @db.SmallInt
  active            Boolean           @default(true)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branches          Branch[]
  warehouses        Warehouse[]
  stockMovements    StockMovement[]
  purchaseBills     PurchaseBill[]
  purchaseReturns   PurchaseReturn[]
  supplierPayments  SupplierPayment[]

  @@unique([organizationId, normalizedCode])
  @@unique([id, organizationId])
  @@index([organizationId, active])
  @@map("companies")
}

model Branch {
  id               String             @id @default(uuid()) @db.Uuid
  organizationId   String             @map("organization_id") @db.Uuid
  companyId        String             @map("company_id") @db.Uuid
  name             String             @db.VarChar(160)
  normalizedCode   String             @map("normalized_code") @db.VarChar(40)
  timezone         String             @default("Asia/Kolkata") @db.VarChar(64)
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  company          Company            @relation(fields: [companyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  userAccess       UserBranchAccess[]
  warehouses       Warehouse[]
  stockMovements   StockMovement[]
  purchaseBills    PurchaseBill[]
  purchaseReturns  PurchaseReturn[]
  supplierPayments SupplierPayment[]

  @@unique([organizationId, normalizedCode])
  @@unique([id, organizationId])
  @@index([organizationId, companyId, active])
  @@map("branches")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(100)
  description String           @db.VarChar(255)
  sensitive   Boolean          @default(false)
  roleLinks   RolePermission[]

  @@map("permissions")
}

model Role {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  code           String           @db.VarChar(60)
  name           String           @db.VarChar(120)
  system         Boolean          @default(false)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  permissions    RolePermission[]
  memberships    MembershipRole[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@map("roles")
}

model RolePermission {
  roleId         String     @map("role_id") @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  permissionId   String     @map("permission_id") @db.Uuid
  role           Role       @relation(fields: [roleId, organizationId], references: [id, organizationId], onDelete: Cascade)
  permission     Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@id([roleId, permissionId])
  @@index([organizationId])
  @@map("role_permissions")
}

model MembershipRole {
  membershipId   String                 @map("membership_id") @db.Uuid
  roleId         String                 @map("role_id") @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  membership     OrganizationMembership @relation(fields: [membershipId, organizationId], references: [id, organizationId], onDelete: Cascade)
  role           Role                   @relation(fields: [roleId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@id([membershipId, roleId])
  @@index([organizationId])
  @@map("membership_roles")
}

model UserBranchAccess {
  membershipId   String                 @map("membership_id") @db.Uuid
  branchId       String                 @map("branch_id") @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  membership     OrganizationMembership @relation(fields: [membershipId, organizationId], references: [id, organizationId], onDelete: Cascade)
  branch         Branch                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@id([membershipId, branchId])
  @@index([organizationId, branchId])
  @@map("user_branch_access")
}

model LoginSession {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  tokenFamilyId String         @map("token_family_id") @db.Uuid
  ipAddress     String?        @map("ip_address") @db.Inet
  userAgent     String?        @map("user_agent") @db.VarChar(500)
  lastSeenAt    DateTime       @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  expiresAt     DateTime       @map("expires_at") @db.Timestamptz(3)
  revokedAt     DateTime?      @map("revoked_at") @db.Timestamptz(3)
  revokeReason  String?        @map("revoke_reason") @db.VarChar(160)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId, revokedAt, expiresAt])
  @@index([tokenFamilyId])
  @@map("login_sessions")
}

model RefreshToken {
  id         String       @id @default(uuid()) @db.Uuid
  sessionId  String       @map("session_id") @db.Uuid
  tokenHash  String       @unique @map("token_hash") @db.Char(64)
  expiresAt  DateTime     @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime?    @map("consumed_at") @db.Timestamptz(3)
  revokedAt  DateTime?    @map("revoked_at") @db.Timestamptz(3)
  replacedBy String?      @map("replaced_by") @db.Uuid
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  session    LoginSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, expiresAt])
  @@map("refresh_tokens")
}

model Plan {
  id       String        @id @default(uuid()) @db.Uuid
  code     String        @unique @db.VarChar(40)
  name     String        @db.VarChar(100)
  active   Boolean       @default(true)
  versions PlanVersion[]

  @@map("plans")
}

model PlanVersion {
  id             String            @id @default(uuid()) @db.Uuid
  planId         String            @map("plan_id") @db.Uuid
  version        Int
  monthlyPrice   Decimal           @map("monthly_price") @db.Decimal(12, 2)
  annualPrice    Decimal           @map("annual_price") @db.Decimal(12, 2)
  currency       String            @default("INR") @db.Char(3)
  effectiveFrom  DateTime          @map("effective_from") @db.Timestamptz(3)
  effectiveUntil DateTime?         @map("effective_until") @db.Timestamptz(3)
  plan           Plan              @relation(fields: [planId], references: [id], onDelete: Restrict)
  entitlements   PlanEntitlement[]
  subscriptions  Subscription[]

  @@unique([planId, version])
  @@map("plan_versions")
}

model PlanEntitlement {
  id            String      @id @default(uuid()) @db.Uuid
  planVersionId String      @map("plan_version_id") @db.Uuid
  key           String      @db.VarChar(100)
  value         Json
  planVersion   PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  @@unique([planVersionId, key])
  @@map("plan_entitlements")
}

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  organizationId         String             @unique @map("organization_id") @db.Uuid
  planVersionId          String             @map("plan_version_id") @db.Uuid
  status                 SubscriptionStatus
  billingInterval        BillingInterval    @map("billing_interval")
  currentPeriodStart     DateTime           @map("current_period_start") @db.Timestamptz(3)
  currentPeriodEnd       DateTime           @map("current_period_end") @db.Timestamptz(3)
  gatewayCustomerRef     String?            @map("gateway_customer_ref") @db.VarChar(180)
  gatewaySubscriptionRef String?            @map("gateway_subscription_ref") @db.VarChar(180)
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  planVersion            PlanVersion        @relation(fields: [planVersionId], references: [id], onDelete: Restrict)

  @@index([status, currentPeriodEnd])
  @@map("subscriptions")
}

model AiSubscription {
  id                     String             @id @default(uuid()) @db.Uuid
  organizationId         String             @unique @map("organization_id") @db.Uuid
  status                 SubscriptionStatus
  monthlyCredits         Int                @default(1500) @map("monthly_credits")
  currentPeriodStart     DateTime           @map("current_period_start") @db.Timestamptz(3)
  currentPeriodEnd       DateTime           @map("current_period_end") @db.Timestamptz(3)
  gatewaySubscriptionRef String?            @map("gateway_subscription_ref") @db.VarChar(180)
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([status, currentPeriodEnd])
  @@map("ai_subscriptions")
}

model AiCreditLedger {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  entryType      AiCreditEntryType @map("entry_type")
  credits        Int
  referenceType  String            @map("reference_type") @db.VarChar(60)
  referenceId    String?           @map("reference_id") @db.Uuid
  expiresAt      DateTime?         @map("expires_at") @db.Timestamptz(3)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, entryType, referenceType, referenceId])
  @@index([organizationId, createdAt])
  @@index([organizationId, expiresAt])
  @@map("ai_credit_ledger")
}

model Category {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  parentId       String?      @map("parent_id") @db.Uuid
  name           String       @db.VarChar(140)
  normalizedCode String       @map("normalized_code") @db.VarChar(50)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  parent         Category?    @relation("CategoryTree", fields: [parentId, organizationId], references: [id, organizationId], onDelete: Restrict)
  children       Category[]   @relation("CategoryTree")
  products       Product[]

  @@unique([organizationId, normalizedCode])
  @@unique([id, organizationId])
  @@index([organizationId, parentId, active])
  @@map("categories")
}

model Unit {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  code           String       @db.VarChar(20)
  name           String       @db.VarChar(80)
  symbol         String       @db.VarChar(20)
  decimalPlaces  Int          @default(3) @map("decimal_places") @db.SmallInt
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  products       Product[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@map("units")
}

model TaxRate {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  code           String       @db.VarChar(30)
  name           String       @db.VarChar(100)
  rate           Decimal      @db.Decimal(5, 2)
  cessRate       Decimal      @default(0) @map("cess_rate") @db.Decimal(5, 2)
  effectiveFrom  DateTime     @map("effective_from") @db.Timestamptz(3)
  effectiveUntil DateTime?    @map("effective_until") @db.Timestamptz(3)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  products       Product[]

  @@unique([organizationId, code, effectiveFrom])
  @@unique([id, organizationId])
  @@index([organizationId, active, effectiveFrom])
  @@map("tax_rates")
}

model Product {
  id               String           @id @default(uuid()) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  categoryId       String?          @map("category_id") @db.Uuid
  baseUnitId       String           @map("base_unit_id") @db.Uuid
  defaultTaxRateId String?          @map("default_tax_rate_id") @db.Uuid
  normalizedCode   String           @map("normalized_code") @db.VarChar(60)
  name             String           @db.VarChar(180)
  description      String?          @db.VarChar(500)
  productType      ProductType      @default(GOODS) @map("product_type")
  hsnSac           String?          @map("hsn_sac") @db.VarChar(12)
  priceTaxMode     PriceTaxMode     @default(EXCLUSIVE) @map("price_tax_mode")
  active           Boolean          @default(true)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  category         Category?        @relation(fields: [categoryId, organizationId], references: [id, organizationId], onDelete: Restrict)
  baseUnit         Unit             @relation(fields: [baseUnitId, organizationId], references: [id, organizationId], onDelete: Restrict)
  defaultTaxRate   TaxRate?         @relation(fields: [defaultTaxRateId, organizationId], references: [id, organizationId], onDelete: Restrict)
  variants         ProductVariant[]

  @@unique([organizationId, normalizedCode])
  @@unique([id, organizationId])
  @@index([organizationId, categoryId, active])
  @@map("products")
}

model ProductVariant {
  id                  String               @id @default(uuid()) @db.Uuid
  organizationId      String               @map("organization_id") @db.Uuid
  productId           String               @map("product_id") @db.Uuid
  sku                 String               @db.VarChar(80)
  name                String?              @db.VarChar(140)
  salePrice           Decimal              @map("sale_price") @db.Decimal(14, 2)
  purchaseCost        Decimal              @default(0) @map("purchase_cost") @db.Decimal(14, 4)
  trackInventory      Boolean              @default(true) @map("track_inventory")
  serialTracked       Boolean              @default(false) @map("serial_tracked")
  active              Boolean              @default(true)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  product             Product              @relation(fields: [productId, organizationId], references: [id, organizationId], onDelete: Restrict)
  barcodes            ProductBarcode[]
  stockMovements      StockMovement[]
  stockBalances       StockBalance[]
  purchaseItems       PurchaseBillItem[]
  purchaseReturnItems PurchaseReturnItem[]

  @@unique([organizationId, sku])
  @@unique([id, organizationId])
  @@index([organizationId, productId, active])
  @@map("product_variants")
}

model ProductBarcode {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  variantId      String         @map("variant_id") @db.Uuid
  barcode        String         @db.VarChar(80)
  barcodeType    String         @default("EAN") @map("barcode_type") @db.VarChar(20)
  primary        Boolean        @default(false)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  variant        ProductVariant @relation(fields: [variantId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([organizationId, barcode])
  @@index([organizationId, variantId])
  @@map("product_barcodes")
}

model Warehouse {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  companyId       String           @map("company_id") @db.Uuid
  branchId        String           @map("branch_id") @db.Uuid
  normalizedCode  String           @map("normalized_code") @db.VarChar(40)
  name            String           @db.VarChar(140)
  saleable        Boolean          @default(true)
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  company         Company          @relation(fields: [companyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  branch          Branch           @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  stockMovements  StockMovement[]
  stockBalances   StockBalance[]
  purchaseBills   PurchaseBill[]
  purchaseReturns PurchaseReturn[]

  @@unique([organizationId, normalizedCode])
  @@unique([id, organizationId])
  @@index([organizationId, branchId, active])
  @@map("warehouses")
}

model StockMovement {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  companyId      String            @map("company_id") @db.Uuid
  branchId       String            @map("branch_id") @db.Uuid
  warehouseId    String            @map("warehouse_id") @db.Uuid
  variantId      String            @map("variant_id") @db.Uuid
  actorUserId    String            @map("actor_user_id") @db.Uuid
  movementType   StockMovementType @map("movement_type")
  quantity       Decimal           @db.Decimal(18, 3)
  unitCost       Decimal           @map("unit_cost") @db.Decimal(14, 4)
  occurredAt     DateTime          @map("occurred_at") @db.Timestamptz(3)
  sourceType     String            @map("source_type") @db.VarChar(60)
  sourceId       String            @map("source_id") @db.Uuid
  idempotencyKey String            @map("idempotency_key") @db.VarChar(120)
  reversalOfId   String?           @map("reversal_of_id") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  company        Company           @relation(fields: [companyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  branch         Branch            @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  warehouse      Warehouse         @relation(fields: [warehouseId, organizationId], references: [id, organizationId], onDelete: Restrict)
  variant        ProductVariant    @relation(fields: [variantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  actor          User              @relation("StockMovementActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  reversalOf     StockMovement?    @relation("StockMovementReversal", fields: [reversalOfId, organizationId], references: [id, organizationId], onDelete: Restrict)
  reversals      StockMovement[]   @relation("StockMovementReversal")

  @@unique([id, organizationId])
  @@unique([organizationId, idempotencyKey, warehouseId, variantId, movementType])
  @@index([organizationId, warehouseId, variantId, occurredAt])
  @@index([organizationId, sourceType, sourceId])
  @@map("stock_movements")
}

model StockBalance {
  organizationId String         @map("organization_id") @db.Uuid
  warehouseId    String         @map("warehouse_id") @db.Uuid
  variantId      String         @map("variant_id") @db.Uuid
  quantity       Decimal        @default(0) @db.Decimal(18, 3)
  averageCost    Decimal        @default(0) @map("average_cost") @db.Decimal(14, 4)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  warehouse      Warehouse      @relation(fields: [warehouseId, organizationId], references: [id, organizationId], onDelete: Restrict)
  variant        ProductVariant @relation(fields: [variantId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@id([organizationId, warehouseId, variantId])
  @@index([organizationId, variantId])
  @@map("stock_balances")
}

model Supplier {
  id              String            @id @default(uuid()) @db.Uuid
  organizationId  String            @map("organization_id") @db.Uuid
  normalizedCode  String            @map("normalized_code") @db.VarChar(60)
  name            String            @db.VarChar(180)
  normalizedName  String            @map("normalized_name") @db.VarChar(180)
  gstin           String?           @db.VarChar(15)
  phone           String?           @db.VarChar(30)
  email           String?           @db.VarChar(320)
  creditDays      Int               @default(0) @map("credit_days") @db.SmallInt
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  purchaseBills   PurchaseBill[]
  purchaseReturns PurchaseReturn[]
  payments        SupplierPayment[]

  @@unique([organizationId, normalizedCode])
  @@unique([id, organizationId])
  @@index([organizationId, normalizedName, active])
  @@map("suppliers")
}

model PurchaseBill {
  id                         String                      @id @default(uuid()) @db.Uuid
  organizationId             String                      @map("organization_id") @db.Uuid
  companyId                  String                      @map("company_id") @db.Uuid
  branchId                   String                      @map("branch_id") @db.Uuid
  warehouseId                String                      @map("warehouse_id") @db.Uuid
  supplierId                 String                      @map("supplier_id") @db.Uuid
  status                     PurchaseBillStatus          @default(DRAFT)
  supplierInvoiceReference   String                      @map("supplier_invoice_reference") @db.VarChar(100)
  normalizedReference        String                      @map("normalized_reference") @db.VarChar(100)
  invoiceDate                DateTime                    @map("invoice_date") @db.Date
  dueDate                    DateTime?                   @map("due_date") @db.Date
  currency                   String                      @default("INR") @db.Char(3)
  taxableValue               Decimal                     @default(0) @map("taxable_value") @db.Decimal(14, 2)
  cgstAmount                 Decimal                     @default(0) @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount                 Decimal                     @default(0) @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount                 Decimal                     @default(0) @map("igst_amount") @db.Decimal(14, 2)
  cessAmount                 Decimal                     @default(0) @map("cess_amount") @db.Decimal(14, 2)
  roundOff                   Decimal                     @default(0) @map("round_off") @db.Decimal(5, 2)
  totalAmount                Decimal                     @default(0) @map("total_amount") @db.Decimal(14, 2)
  paidAmount                 Decimal                     @default(0) @map("paid_amount") @db.Decimal(14, 2)
  returnedAmount             Decimal                     @default(0) @map("returned_amount") @db.Decimal(14, 2)
  outstandingAmount          Decimal                     @default(0) @map("outstanding_amount") @db.Decimal(14, 2)
  inputTaxEligible           Boolean                     @default(false) @map("input_tax_eligible")
  postingIdempotencyKey      String?                     @map("posting_idempotency_key") @db.VarChar(120)
  postedAt                   DateTime?                   @map("posted_at") @db.Timestamptz(3)
  postedByUserId             String?                     @map("posted_by_user_id") @db.Uuid
  cancellationIdempotencyKey String?                     @map("cancellation_idempotency_key") @db.VarChar(120)
  cancelledAt                DateTime?                   @map("cancelled_at") @db.Timestamptz(3)
  cancelledByUserId          String?                     @map("cancelled_by_user_id") @db.Uuid
  cancellationReason         String?                     @map("cancellation_reason") @db.VarChar(500)
  createdAt                  DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                  DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization               Organization                @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  company                    Company                     @relation(fields: [companyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  branch                     Branch                      @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  warehouse                  Warehouse                   @relation(fields: [warehouseId, organizationId], references: [id, organizationId], onDelete: Restrict)
  supplier                   Supplier                    @relation(fields: [supplierId, organizationId], references: [id, organizationId], onDelete: Restrict)
  postedBy                   User?                       @relation("PurchaseBillPostedBy", fields: [postedByUserId], references: [id], onDelete: Restrict)
  cancelledBy                User?                       @relation("PurchaseBillCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: Restrict)
  items                      PurchaseBillItem[]
  returns                    PurchaseReturn[]
  allocations                SupplierPaymentAllocation[]

  @@unique([id, organizationId])
  @@unique([organizationId, companyId, supplierId, normalizedReference])
  @@unique([organizationId, postingIdempotencyKey])
  @@unique([organizationId, cancellationIdempotencyKey])
  @@index([organizationId, branchId, status, invoiceDate])
  @@index([organizationId, supplierId, status, dueDate])
  @@map("purchase_bills")
}

model PurchaseBillItem {
  id               String               @id @default(uuid()) @db.Uuid
  organizationId   String               @map("organization_id") @db.Uuid
  purchaseBillId   String               @map("purchase_bill_id") @db.Uuid
  variantId        String               @map("variant_id") @db.Uuid
  description      String               @db.VarChar(240)
  hsnSac           String?              @map("hsn_sac") @db.VarChar(12)
  quantity         Decimal              @db.Decimal(18, 3)
  unitCost         Decimal              @map("unit_cost") @db.Decimal(14, 4)
  discountAmount   Decimal              @default(0) @map("discount_amount") @db.Decimal(14, 2)
  taxableValue     Decimal              @map("taxable_value") @db.Decimal(14, 2)
  taxRate          Decimal              @map("tax_rate") @db.Decimal(5, 2)
  cgstAmount       Decimal              @default(0) @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount       Decimal              @default(0) @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount       Decimal              @default(0) @map("igst_amount") @db.Decimal(14, 2)
  cessAmount       Decimal              @default(0) @map("cess_amount") @db.Decimal(14, 2)
  lineTotal        Decimal              @map("line_total") @db.Decimal(14, 2)
  inputTaxEligible Boolean              @default(false) @map("input_tax_eligible")
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  purchaseBill     PurchaseBill         @relation(fields: [purchaseBillId, organizationId], references: [id, organizationId], onDelete: Cascade)
  variant          ProductVariant       @relation(fields: [variantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  returnItems      PurchaseReturnItem[]

  @@unique([id, organizationId])
  @@index([organizationId, purchaseBillId])
  @@map("purchase_bill_items")
}

model PurchaseReturn {
  id                     String               @id @default(uuid()) @db.Uuid
  organizationId         String               @map("organization_id") @db.Uuid
  companyId              String               @map("company_id") @db.Uuid
  branchId               String               @map("branch_id") @db.Uuid
  warehouseId            String               @map("warehouse_id") @db.Uuid
  supplierId             String               @map("supplier_id") @db.Uuid
  purchaseBillId         String               @map("purchase_bill_id") @db.Uuid
  returnDate             DateTime             @map("return_date") @db.Date
  reason                 String               @db.VarChar(500)
  taxableValue           Decimal              @map("taxable_value") @db.Decimal(14, 2)
  cgstAmount             Decimal              @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount             Decimal              @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount             Decimal              @map("igst_amount") @db.Decimal(14, 2)
  cessAmount             Decimal              @map("cess_amount") @db.Decimal(14, 2)
  roundOff               Decimal              @default(0) @map("round_off") @db.Decimal(5, 2)
  totalAmount            Decimal              @map("total_amount") @db.Decimal(14, 2)
  appliedToPayableAmount Decimal              @map("applied_to_payable_amount") @db.Decimal(14, 2)
  supplierCreditAmount   Decimal              @map("supplier_credit_amount") @db.Decimal(14, 2)
  idempotencyKey         String               @map("idempotency_key") @db.VarChar(120)
  postedAt               DateTime             @default(now()) @map("posted_at") @db.Timestamptz(3)
  postedByUserId         String               @map("posted_by_user_id") @db.Uuid
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  organization           Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  company                Company              @relation(fields: [companyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  branch                 Branch               @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  warehouse              Warehouse            @relation(fields: [warehouseId, organizationId], references: [id, organizationId], onDelete: Restrict)
  supplier               Supplier             @relation(fields: [supplierId, organizationId], references: [id, organizationId], onDelete: Restrict)
  purchaseBill           PurchaseBill         @relation(fields: [purchaseBillId, organizationId], references: [id, organizationId], onDelete: Restrict)
  postedBy               User                 @relation("PurchaseReturnPostedBy", fields: [postedByUserId], references: [id], onDelete: Restrict)
  items                  PurchaseReturnItem[]

  @@unique([id, organizationId])
  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, purchaseBillId, returnDate])
  @@index([organizationId, supplierId, returnDate])
  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id                 String           @id @default(uuid()) @db.Uuid
  organizationId     String           @map("organization_id") @db.Uuid
  purchaseReturnId   String           @map("purchase_return_id") @db.Uuid
  purchaseBillItemId String           @map("purchase_bill_item_id") @db.Uuid
  variantId          String           @map("variant_id") @db.Uuid
  quantity           Decimal          @db.Decimal(18, 3)
  unitCost           Decimal          @map("unit_cost") @db.Decimal(14, 4)
  taxableValue       Decimal          @map("taxable_value") @db.Decimal(14, 2)
  cgstAmount         Decimal          @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount         Decimal          @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount         Decimal          @map("igst_amount") @db.Decimal(14, 2)
  cessAmount         Decimal          @map("cess_amount") @db.Decimal(14, 2)
  lineTotal          Decimal          @map("line_total") @db.Decimal(14, 2)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  purchaseReturn     PurchaseReturn   @relation(fields: [purchaseReturnId, organizationId], references: [id, organizationId], onDelete: Restrict)
  purchaseBillItem   PurchaseBillItem @relation(fields: [purchaseBillItemId, organizationId], references: [id, organizationId], onDelete: Restrict)
  variant            ProductVariant   @relation(fields: [variantId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([id, organizationId])
  @@unique([organizationId, purchaseReturnId, purchaseBillItemId])
  @@index([organizationId, purchaseBillItemId])
  @@map("purchase_return_items")
}

model SupplierPayment {
  id             String                      @id @default(uuid()) @db.Uuid
  organizationId String                      @map("organization_id") @db.Uuid
  companyId      String                      @map("company_id") @db.Uuid
  branchId       String                      @map("branch_id") @db.Uuid
  supplierId     String                      @map("supplier_id") @db.Uuid
  actorUserId    String                      @map("actor_user_id") @db.Uuid
  status         SupplierPaymentStatus       @default(POSTED)
  method         PaymentMethod
  amount         Decimal                     @db.Decimal(14, 2)
  reference      String?                     @db.VarChar(120)
  paidAt         DateTime                    @map("paid_at") @db.Timestamptz(3)
  idempotencyKey String                      @map("idempotency_key") @db.VarChar(120)
  createdAt      DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  organization   Organization                @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  company        Company                     @relation(fields: [companyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  branch         Branch                      @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)
  supplier       Supplier                    @relation(fields: [supplierId, organizationId], references: [id, organizationId], onDelete: Restrict)
  actor          User                        @relation("SupplierPaymentActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  allocations    SupplierPaymentAllocation[]

  @@unique([id, organizationId])
  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, supplierId, paidAt])
  @@map("supplier_payments")
}

model SupplierPaymentAllocation {
  organizationId String          @map("organization_id") @db.Uuid
  paymentId      String          @map("payment_id") @db.Uuid
  purchaseBillId String          @map("purchase_bill_id") @db.Uuid
  amount         Decimal         @db.Decimal(14, 2)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  payment        SupplierPayment @relation(fields: [paymentId, organizationId], references: [id, organizationId], onDelete: Restrict)
  purchaseBill   PurchaseBill    @relation(fields: [purchaseBillId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@id([organizationId, paymentId, purchaseBillId])
  @@index([organizationId, purchaseBillId])
  @@map("supplier_payment_allocations")
}

model AuditLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  actorUserId    String?      @map("actor_user_id") @db.Uuid
  action         String       @db.VarChar(120)
  targetType     String       @map("target_type") @db.VarChar(80)
  targetId       String?      @map("target_id") @db.Uuid
  correlationId  String       @map("correlation_id") @db.Uuid
  outcome        String       @db.VarChar(40)
  summary        Json?
  occurredAt     DateTime     @default(now()) @map("occurred_at") @db.Timestamptz(3)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, occurredAt])
  @@index([organizationId, targetType, targetId])
  @@map("audit_logs")
}
