generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  INVITED
  ACTIVE
  LOCKED
  DISABLED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum OrganizationStatus {
  TRIALING
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum AiCreditEntryType {
  GRANT
  CONSUME
  REFUND
  EXPIRE
  PURCHASE
}

model User {
  id              String                   @id @default(uuid()) @db.Uuid
  email           String                   @unique @db.VarChar(320)
  normalizedEmail String                   @unique @map("normalized_email") @db.VarChar(320)
  displayName     String                   @map("display_name") @db.VarChar(160)
  passwordHash    String?                  @map("password_hash") @db.VarChar(255)
  status          UserStatus               @default(INVITED)
  emailVerifiedAt DateTime?                @map("email_verified_at") @db.Timestamptz(3)
  lastLoginAt     DateTime?                @map("last_login_at") @db.Timestamptz(3)
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  memberships     OrganizationMembership[]
  sessions        LoginSession[]

  @@map("users")
}

model Organization {
  id               String                   @id @default(uuid()) @db.Uuid
  name             String                   @db.VarChar(180)
  slug             String                   @unique @db.VarChar(100)
  status           OrganizationStatus       @default(TRIALING)
  locale           String                   @default("en-IN") @db.VarChar(16)
  timezone         String                   @default("Asia/Kolkata") @db.VarChar(64)
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  memberships      OrganizationMembership[]
  companies        Company[]
  branches         Branch[]
  roles            Role[]
  coreSubscription Subscription?
  aiSubscription   AiSubscription?
  aiCreditEntries  AiCreditLedger[]
  auditLogs        AuditLog[]

  @@map("organizations")
}

model OrganizationMembership {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  userId         String             @map("user_id") @db.Uuid
  status         MembershipStatus   @default(INVITED)
  joinedAt       DateTime?          @map("joined_at") @db.Timestamptz(3)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user           User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  roles          MembershipRole[]
  branchAccess   UserBranchAccess[]

  @@unique([organizationId, userId])
  @@unique([id, organizationId])
  @@index([userId, status])
  @@map("organization_memberships")
}

model Company {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @map("organization_id") @db.Uuid
  legalName         String       @map("legal_name") @db.VarChar(200)
  tradeName         String?      @map("trade_name") @db.VarChar(200)
  normalizedCode    String       @map("normalized_code") @db.VarChar(40)
  gstin             String?      @db.VarChar(15)
  financialYearFrom Int          @default(4) @map("financial_year_from") @db.SmallInt
  active            Boolean      @default(true)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branches          Branch[]

  @@unique([organizationId, normalizedCode])
  @@unique([id, organizationId])
  @@index([organizationId, active])
  @@map("companies")
}

model Branch {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  companyId      String             @map("company_id") @db.Uuid
  name           String             @db.VarChar(160)
  normalizedCode String             @map("normalized_code") @db.VarChar(40)
  timezone       String             @default("Asia/Kolkata") @db.VarChar(64)
  active         Boolean            @default(true)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  company        Company            @relation(fields: [companyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  userAccess     UserBranchAccess[]

  @@unique([organizationId, normalizedCode])
  @@unique([id, organizationId])
  @@index([organizationId, companyId, active])
  @@map("branches")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(100)
  description String           @db.VarChar(255)
  sensitive   Boolean          @default(false)
  roleLinks   RolePermission[]

  @@map("permissions")
}

model Role {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  code           String           @db.VarChar(60)
  name           String           @db.VarChar(120)
  system         Boolean          @default(false)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  permissions    RolePermission[]
  memberships    MembershipRole[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@map("roles")
}

model RolePermission {
  roleId         String     @map("role_id") @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  permissionId   String     @map("permission_id") @db.Uuid
  role           Role       @relation(fields: [roleId, organizationId], references: [id, organizationId], onDelete: Cascade)
  permission     Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@id([roleId, permissionId])
  @@index([organizationId])
  @@map("role_permissions")
}

model MembershipRole {
  membershipId   String                 @map("membership_id") @db.Uuid
  roleId         String                 @map("role_id") @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  membership     OrganizationMembership @relation(fields: [membershipId, organizationId], references: [id, organizationId], onDelete: Cascade)
  role           Role                   @relation(fields: [roleId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@id([membershipId, roleId])
  @@index([organizationId])
  @@map("membership_roles")
}

model UserBranchAccess {
  membershipId   String                 @map("membership_id") @db.Uuid
  branchId       String                 @map("branch_id") @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  membership     OrganizationMembership @relation(fields: [membershipId, organizationId], references: [id, organizationId], onDelete: Cascade)
  branch         Branch                 @relation(fields: [branchId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@id([membershipId, branchId])
  @@index([organizationId, branchId])
  @@map("user_branch_access")
}

model LoginSession {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  tokenFamilyId String         @map("token_family_id") @db.Uuid
  ipAddress     String?        @map("ip_address") @db.Inet
  userAgent     String?        @map("user_agent") @db.VarChar(500)
  lastSeenAt    DateTime       @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  expiresAt     DateTime       @map("expires_at") @db.Timestamptz(3)
  revokedAt     DateTime?      @map("revoked_at") @db.Timestamptz(3)
  revokeReason  String?        @map("revoke_reason") @db.VarChar(160)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId, revokedAt, expiresAt])
  @@index([tokenFamilyId])
  @@map("login_sessions")
}

model RefreshToken {
  id         String       @id @default(uuid()) @db.Uuid
  sessionId  String       @map("session_id") @db.Uuid
  tokenHash  String       @unique @map("token_hash") @db.Char(64)
  expiresAt  DateTime     @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime?    @map("consumed_at") @db.Timestamptz(3)
  revokedAt  DateTime?    @map("revoked_at") @db.Timestamptz(3)
  replacedBy String?      @map("replaced_by") @db.Uuid
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  session    LoginSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, expiresAt])
  @@map("refresh_tokens")
}

model Plan {
  id       String        @id @default(uuid()) @db.Uuid
  code     String        @unique @db.VarChar(40)
  name     String        @db.VarChar(100)
  active   Boolean       @default(true)
  versions PlanVersion[]

  @@map("plans")
}

model PlanVersion {
  id             String            @id @default(uuid()) @db.Uuid
  planId         String            @map("plan_id") @db.Uuid
  version        Int
  monthlyPrice   Decimal           @map("monthly_price") @db.Decimal(12, 2)
  annualPrice    Decimal           @map("annual_price") @db.Decimal(12, 2)
  currency       String            @default("INR") @db.Char(3)
  effectiveFrom  DateTime          @map("effective_from") @db.Timestamptz(3)
  effectiveUntil DateTime?         @map("effective_until") @db.Timestamptz(3)
  plan           Plan              @relation(fields: [planId], references: [id], onDelete: Restrict)
  entitlements   PlanEntitlement[]
  subscriptions  Subscription[]

  @@unique([planId, version])
  @@map("plan_versions")
}

model PlanEntitlement {
  id            String      @id @default(uuid()) @db.Uuid
  planVersionId String      @map("plan_version_id") @db.Uuid
  key           String      @db.VarChar(100)
  value         Json
  planVersion   PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  @@unique([planVersionId, key])
  @@map("plan_entitlements")
}

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  organizationId         String             @unique @map("organization_id") @db.Uuid
  planVersionId          String             @map("plan_version_id") @db.Uuid
  status                 SubscriptionStatus
  billingInterval        BillingInterval    @map("billing_interval")
  currentPeriodStart     DateTime           @map("current_period_start") @db.Timestamptz(3)
  currentPeriodEnd       DateTime           @map("current_period_end") @db.Timestamptz(3)
  gatewayCustomerRef     String?            @map("gateway_customer_ref") @db.VarChar(180)
  gatewaySubscriptionRef String?            @map("gateway_subscription_ref") @db.VarChar(180)
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  planVersion            PlanVersion        @relation(fields: [planVersionId], references: [id], onDelete: Restrict)

  @@index([status, currentPeriodEnd])
  @@map("subscriptions")
}

model AiSubscription {
  id                     String             @id @default(uuid()) @db.Uuid
  organizationId         String             @unique @map("organization_id") @db.Uuid
  status                 SubscriptionStatus
  monthlyCredits         Int                @default(1500) @map("monthly_credits")
  currentPeriodStart     DateTime           @map("current_period_start") @db.Timestamptz(3)
  currentPeriodEnd       DateTime           @map("current_period_end") @db.Timestamptz(3)
  gatewaySubscriptionRef String?            @map("gateway_subscription_ref") @db.VarChar(180)
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([status, currentPeriodEnd])
  @@map("ai_subscriptions")
}

model AiCreditLedger {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  entryType      AiCreditEntryType @map("entry_type")
  credits        Int
  referenceType  String            @map("reference_type") @db.VarChar(60)
  referenceId    String?           @map("reference_id") @db.Uuid
  expiresAt      DateTime?         @map("expires_at") @db.Timestamptz(3)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
  @@index([organizationId, expiresAt])
  @@map("ai_credit_ledger")
}

model AuditLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  actorUserId    String?      @map("actor_user_id") @db.Uuid
  action         String       @db.VarChar(120)
  targetType     String       @map("target_type") @db.VarChar(80)
  targetId       String?      @map("target_id") @db.Uuid
  correlationId  String       @map("correlation_id") @db.Uuid
  outcome        String       @db.VarChar(40)
  summary        Json?
  occurredAt     DateTime     @default(now()) @map("occurred_at") @db.Timestamptz(3)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, occurredAt])
  @@index([organizationId, targetType, targetId])
  @@map("audit_logs")
}
